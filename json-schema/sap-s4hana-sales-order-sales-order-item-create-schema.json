    "to_PricingElement": {
      "type": "array",
      "description": "Pricing elements (deep insert)"
    },
    "to_ScheduleLine": {
      "type": "array",
      "description": "Schedule lines (deep insert)"
    },
    "to_Partner": {
      "type": "array",
      "description": "Partners (deep insert)"
    },
    "to_Text": {
      "type": "array",
      "description": "Text records (deep insert)"
