    "RequestedQuantity": {
      "type": "string",
      "description": "Requested quantity"
    },
    "RequestedQuantityUnit": {
      "type": "string",
      "description": "Unit of measure"
    },
    "Plant": {
      "type": "string",
      "description": "Plant"
    },
    "SalesOrderItemCategory": {
      "type": "string",
      "description": "Item category"
